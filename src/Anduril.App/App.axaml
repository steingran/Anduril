<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Anduril.App.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Tokens.axaml" />
                <ResourceInclude Source="/Styles/Brushes.axaml" />
                <ResourceInclude Source="/Styles/Icons.axaml" />
                <ResourceInclude Source="/Styles/Motion.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="PopupRoot">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
        </Style>
        <Style Selector="FlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
        </Style>
        <StyleInclude Source="/Styles/Type.axaml" />
        <StyleInclude Source="/Styles/Buttons.axaml" />
        <StyleInclude Source="/Styles/Inputs.axaml" />
        <StyleInclude Source="/Styles/SidebarList.axaml" />
        <StyleInclude Source="/Styles/SegmentedControl.axaml" />
        <StyleInclude Source="/Styles/Markdown.axaml" />
    </Application.Styles>

</Application>
