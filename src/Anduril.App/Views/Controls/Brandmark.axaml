<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Anduril.App.Views.Controls.Brandmark"
             x:Name="Root">

    <StackPanel x:Name="LayoutRoot"
                Orientation="Horizontal"
                VerticalAlignment="Center">
        <Image x:Name="MarkImage"
               Source="/Assets/anduril-mark.svg"
               Stretch="Uniform" />
        <Grid x:Name="WordmarkHost">
            <Image x:Name="LightWordmarkImage"
                   Source="/Assets/anduril-wordmark-light.svg"
                   Stretch="Uniform" />
            <Image x:Name="DarkWordmarkImage"
                   Source="/Assets/anduril-wordmark-dark.svg"
                   Stretch="Uniform" />
        </Grid>
    </StackPanel>

</UserControl>
