<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Anduril.App.Views.Controls.StreamingDotIndicator"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Ellipse.dot">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Fill" Value="#5A8ADB" />
            <Setter Property="Opacity" Value="0.3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Staggered pulse: each dot peaks 200 ms after the previous one -->
        <Style Selector="Ellipse.dot1">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="16%"> <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%"> <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Ellipse.dot2">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE" Delay="0:0:0.2">
                    <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="16%"> <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%"> <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Ellipse.dot3">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE" Delay="0:0:0.4">
                    <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="16%"> <Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="60%"> <Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <!-- Container visibility is driven by the IsStreaming StyledProperty via code-behind. Starts hidden. -->
    <StackPanel x:Name="DotsPanel"
                IsVisible="False"
                Orientation="Horizontal"
                Spacing="6"
                VerticalAlignment="Center">
        <Ellipse Classes="dot dot1" />
        <Ellipse Classes="dot dot2" />
        <Ellipse Classes="dot dot3" />
    </StackPanel>

</UserControl>

