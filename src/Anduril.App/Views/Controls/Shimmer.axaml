<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Anduril.App.Views.Controls.Shimmer"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Border.shimmer-line">
            <Setter Property="Height" Value="14" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusS}" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="Border.shimmer-line.animated">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.45" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.95" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.45" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.shimmer-line.reduced">
            <Setter Property="Opacity" Value="0.6" />
        </Style>
    </UserControl.Styles>

    <ItemsControl x:Name="LinesList" ItemsSource="{Binding Lines, ElementName=Root}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Classes="shimmer-line"
                        Height="{Binding ElementName=Root, Path=LineHeight}"
                        Width="{Binding}"
                        Margin="0,0,0,6"
                        IsVisible="True" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>

</UserControl>
