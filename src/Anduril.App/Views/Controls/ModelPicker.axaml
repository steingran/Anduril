<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Anduril.App.Converters"
             xmlns:local="using:Anduril.App.Views.Controls"
             x:Class="Anduril.App.Views.Controls.ModelPicker"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Border.model-picker-root">
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.model-picker-trigger">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style Selector="Button.model-picker-trigger:focus-visible /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilFocusVisibleThickness}" />
        </Style>

        <Style Selector="Border.model-picker-popup">
            <Setter Property="MinWidth" Value="280" />
            <Setter Property="MaxHeight" Value="300" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusL}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="BoxShadow" Value="0 2 10 0 #000A" />
        </Style>

        <Style Selector="TextBlock.model-picker-placeholder">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.model-picker-selected">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.model-picker-provider">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextTertiaryBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.4" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style Selector="Button.model-option">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style Selector="Button.model-option:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
        </Style>

        <Style Selector="Button.model-option:disabled">
            <Setter Property="Opacity" Value="0.6" />
        </Style>

        <Style Selector="Button.model-picker-configure">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilAccentBrush}" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Styles>

    <Border x:Name="PickerRoot" Classes="model-picker-root">
        <Grid>
                    <Button x:Name="OpenButton"
                            Classes="model-picker-trigger"
                            Click="OnTogglePopup"
                            HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock x:Name="SelectedModelText"
                               Text="{Binding PlaceholderText, ElementName=Root}"
                               Classes="model-picker-placeholder"
                               Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                    <TextBlock Text="▾"
                               Classes="model-picker-selected"
                               Foreground="{DynamicResource AndurilTextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>

                    <Popup x:Name="ModelPopup"
                           PlacementTarget="{Binding #OpenButton}"
                           Placement="Bottom"
                           IsOpen="False"
                           HorizontalAlignment="Stretch"
                           IsLightDismissEnabled="True">
                <Border Classes="model-picker-popup">
                    <DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="OptionList" ItemsSource="{Binding PickerItems, ElementName=Root}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ModelPickerItem">
                                        <Grid>
                                            <TextBlock Classes="model-picker-provider"
                                                       IsVisible="{Binding IsProviderHeader}"
                                                       Text="{Binding ProviderName}" />

                                            <Button x:Name="ModelButton"
                                                    Classes="model-option"
                                                    IsVisible="{Binding IsModelOption}"
                                                    IsEnabled="{Binding Model.IsAvailable}"
                                                    Click="OnSelectModel"
                                                    DataContext="{Binding}">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{Binding Model.IsAvailable, Converter={x:Static converters:BoolToBrushConverter.Instance}}"
                                                             VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="{Binding Model.DisplayName}"
                                                                   Classes="model-picker-selected"
                                                                   Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Model.ModelName}"
                                                                   Classes="model-picker-placeholder"
                                                                   Foreground="{DynamicResource AndurilTextSecondaryBrush}"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding AvailabilityLabel}"
                                                               Classes="model-picker-placeholder"
                                                               Foreground="{DynamicResource AndurilTextSecondaryBrush}"
                                                               HorizontalAlignment="Right"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button x:Name="ConfigureButton"
                                Classes="model-picker-configure"
                                Content="{Binding ConfigureLabel, ElementName=Root}"
                                IsVisible="{Binding HasConfigureAction, ElementName=Root}"
                                Command="{Binding ConfigureCommand, ElementName=Root}" />
                    </DockPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>

</UserControl>
