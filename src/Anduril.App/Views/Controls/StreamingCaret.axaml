<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Anduril.App.Views.Controls.StreamingCaret"
             x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Rectangle.caret">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="16" />
            <Setter Property="RadiusX" Value="0" />
            <Setter Property="RadiusY" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Rectangle.caret.blink">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Rectangle x:Name="Caret"
               Classes="caret"
               IsVisible="False" />

</UserControl>
