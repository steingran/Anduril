<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Anduril.App.ViewModels"
             xmlns:models="using:Anduril.App.Models"
             xmlns:controls="using:Anduril.App.Views.Controls"
             x:Class="Anduril.App.Views.CodeView"
             x:Name="Root"
             x:DataType="vm:CodeViewModel">

    <UserControl.Styles>
        <Style Selector="Border.code-root">
            <Setter Property="Background" Value="{DynamicResource AndurilCodeSurfaceBrush}" />
        </Style>

        <Style Selector="Border.repo-bar">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilDividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style Selector="Button.repo-browse">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style Selector="Button.repo-browse:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceAltBrush}" />
        </Style>

        <Style Selector="Border.repo-chip">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="10,5" />
        </Style>

        <Style Selector="TextBlock.repo-chip-text">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="ComboBox.branch-selector">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        </Style>

        <Style Selector="Border.empty-state-card">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusXl}" />
            <Setter Property="Padding" Value="32" />
            <Setter Property="MaxWidth" Value="520" />
        </Style>

        <Style Selector="Border.message-shell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TextBlock.message-body">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeBody}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="22" />
        </Style>

        <Style Selector="TextBlock.message-body.code">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,monospace" />
        </Style>

        <Style Selector="TextBlock.message-meta">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextTertiaryBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="Button.show-more">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilAccentBrush}" />
        </Style>

        <Style Selector="Border.composer-shell">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusXl}" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="20,0,20,20" />
        </Style>

        <Style Selector="TextBox.code-input">
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="MaxHeight" Value="180" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusL}" />
        </Style>

        <Style Selector="Button.send">
            <Setter Property="Width" Value="88" />
        </Style>

        <Style Selector="Button.stop">
            <Setter Property="Width" Value="88" />
        </Style>

        <Style Selector="Button.stop /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.slash-chip">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style Selector="Button.slash-chip-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="Border.staged-panel">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilDividerBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="Width" Value="480" />
        </Style>

        <Style Selector="Button.accept">
            <Setter Property="Background" Value="{DynamicResource AndurilSuccessSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilSuccessBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style Selector="Button.reject">
            <Setter Property="Background" Value="{DynamicResource AndurilDangerSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilDangerBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style Selector="Button.ghost-chip">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
    </UserControl.Styles>

    <Border Classes="code-root">
        <Grid ColumnDefinitions="*,Auto">
            <DockPanel Grid.Column="0"
                       LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Classes="repo-bar">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                          ColumnSpacing="{DynamicResource AndurilSpacingS}"
                          VerticalAlignment="Center">
                        <Button x:Name="BrowseRepoButton"
                                Classes="repo-browse"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <PathIcon Width="14"
                                          Height="14"
                                          Data="{StaticResource FluentFolderOpen16Geometry}"
                                          Foreground="{DynamicResource AndurilTextSecondaryBrush}" />
                                <TextBlock Text="Browse repo..."
                                           Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                            </StackPanel>
                        </Button>

                        <Border Grid.Column="1"
                                Classes="repo-chip"
                                IsVisible="{Binding HasSelectedRepo}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <PathIcon Width="14"
                                          Height="14"
                                          Data="{StaticResource FluentFolderOpen16Geometry}"
                                          Foreground="{DynamicResource AndurilTextSecondaryBrush}" />
                                <TextBlock Classes="repo-chip-text"
                                           Text="{Binding RepoDisplayName}" />
                            </StackPanel>
                        </Border>

                        <ComboBox Grid.Column="2"
                                  Classes="branch-selector"
                                  IsVisible="{Binding HasSelectedRepo}"
                                  ItemsSource="{Binding AvailableBranches}"
                                  SelectedItem="{Binding SelectedBranch}"
                                  PlaceholderText="branch" />

                        <controls:PathBreadcrumb Grid.Column="3"
                                                 Margin="0,0,0,0"
                                                 VerticalAlignment="Center"
                                                 IsVisible="{Binding HasSelectedRepo}"
                                                 Path="{Binding SelectedRepoPath}" />
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Classes="composer-shell"
                        IsEnabled="{Binding HasSelectedRepo}">
                    <StackPanel Spacing="{DynamicResource AndurilSpacingM}">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{DynamicResource AndurilSpacingS}">
                            <TextBox Grid.Column="0"
                                     Classes="code-input"
                                     Text="{Binding InputText}"
                                     AcceptsReturn="True"
                                     Watermark="Ask Anduril to inspect, patch, or explain this repo...">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Ctrl+Return" Command="{Binding SendCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>

                            <Grid Grid.Column="1"
                                  Width="88">
                                <Button Classes="accent send"
                                        Content="Send"
                                        Command="{Binding SendCommand}"
                                        IsVisible="{Binding !IsStreaming}"
                                        HorizontalAlignment="Stretch" />
                                <Button Classes="ghost stop"
                                        Command="{Binding StopCommand}"
                                        IsVisible="{Binding IsStreaming}"
                                        ToolTip.Tip="Stop generation">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="8"
                                          HorizontalAlignment="Center">
                                        <Rectangle Width="10"
                                                   Height="10"
                                                   RadiusX="2"
                                                   RadiusY="2"
                                                   Fill="{DynamicResource AndurilDangerBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Stop"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="{DynamicResource AndurilSpacingS}"
                                    IsVisible="{Binding HasSelectedRepo}">
                            <TextBlock Text="Slash commands"
                                       Classes="message-meta"
                                       VerticalAlignment="Center" />
                            <ItemsControl ItemsSource="{Binding SlashCommands}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="{DynamicResource AndurilSpacingS}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="slash-chip">
                                            <Button Classes="slash-chip-button"
                                                    Command="{Binding #Root.DataContext.InsertSlashCommandCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="{Binding .}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,0">
                    <ScrollViewer x:Name="MessagesScroll"
                                  IsVisible="{Binding HasSelectedRepo}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Messages}"
                                      Margin="20,20,20,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:CodeMessageModel">
                                    <Grid Margin="0,0,0,18"
                                          ColumnDefinitions="Auto,*,Auto">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{DynamicResource AndurilAccentBrush}"
                                                 VerticalAlignment="Top"
                                                 Margin="0,7,12,0"
                                                 IsVisible="{Binding IsAssistant}" />

                                        <StackPanel Grid.Column="1"
                                                    Spacing="{DynamicResource AndurilSpacingS}"
                                                    IsVisible="{Binding IsAssistant}">
                                            <TextBlock Classes="message-meta"
                                                       Text="Anduril" />
                                            <Panel>
                                                <controls:StreamingDotIndicator IsStreaming="{Binding IsLoading}" />
                                                <Border MaxHeight="{Binding ContentMaxHeight}"
                                                        Classes="message-shell"
                                                        IsVisible="{Binding !IsLoading}">
                                                    <TextBlock Text="{Binding Content}"
                                                               Classes="message-body code" />
                                                </Border>
                                            </Panel>
                                            <Button Classes="show-more"
                                                    IsVisible="{Binding IsCollapsible}"
                                                    Command="{Binding ToggleExpandCommand}"
                                                    Content="{Binding ShowMoreLabel}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="{DynamicResource AndurilSpacingS}"
                                                    HorizontalAlignment="Right"
                                                    IsVisible="{Binding IsUser}">
                                            <TextBlock Classes="message-meta"
                                                       HorizontalAlignment="Right"
                                                       Text="You" />
                                            <Border Classes="message-shell"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Right"
                                                    MaxHeight="{Binding ContentMaxHeight}">
                                                <TextBlock Text="{Binding Content}"
                                                           Classes="message-body" />
                                            </Border>
                                            <Button Classes="show-more"
                                                    IsVisible="{Binding IsCollapsible}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding ToggleExpandCommand}"
                                                    Content="{Binding ShowMoreLabel}" />
                                        </StackPanel>

                                        <Ellipse Grid.Column="2"
                                                 Width="10"
                                                 Height="10"
                                                 Fill="{DynamicResource AndurilTextSecondaryBrush}"
                                                 VerticalAlignment="Top"
                                                 Margin="12,7,0,0"
                                                 IsVisible="{Binding IsUser}" />

                                        <controls:InlineStatus Grid.Column="0"
                                                               Grid.ColumnSpan="3"
                                                               IsVisible="{Binding IsStopped}"
                                                               Text="Stopped"
                                                               Variant="Stopped"
                                                               HorizontalAlignment="Left" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Classes="empty-state-card"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding !HasSelectedRepo}">
                        <StackPanel Spacing="{DynamicResource AndurilSpacingM}">
                            <TextBlock Text="Choose a repository to start a code session"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                            <TextBlock Text="Anduril will use the selected repo for branch context, staged diffs, and code-focused slash commands."
                                       Classes="message-body" />
                            <Button Classes="accent"
                                    HorizontalAlignment="Left"
                                    Click="OnBrowseRepoClicked"
                                    Content="Browse…" />
                        </StackPanel>
                    </Border>

                    <Button Classes="ghost-chip"
                            IsVisible="{Binding ShowStagedActionsOverlay}"
                            Command="{Binding ShowStagedActionsCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,20,20"
                            Content="{Binding StagedActionsOverlayLabel}" />
                </Grid>
            </DockPanel>

            <Border Grid.Column="1"
                    Classes="staged-panel"
                    IsVisible="{Binding IsStagedPanelVisible}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource AndurilSurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource AndurilDividerBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,14">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                              ColumnSpacing="{DynamicResource AndurilSpacingS}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Staged changes"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                                <TextBlock Text="Review each proposal before applying it to the repo."
                                           Classes="message-meta" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Classes="reject"
                                    Command="{Binding RejectAllCommand}"
                                    Content="Reject all" />
                            <Button Grid.Column="2"
                                    Classes="accept"
                                    Command="{Binding AcceptAllCommand}"
                                    Content="Accept all" />
                            <Button Grid.Column="3"
                                    Classes="ghost"
                                    IsVisible="{Binding IsCompactLayout}"
                                    Command="{Binding HideStagedActionsCommand}"
                                    Content="Hide" />
                        </Grid>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding StagedActions}"
                                      Margin="16,16,16,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StagedActionModel">
                                    <controls:DiffCard Margin="0,0,0,14"
                                                       FilePath="{Binding FilePath}"
                                                       Kind="{Binding Kind}"
                                                       DiffLines="{Binding VisibleDiffLines}"
                                                       AcceptCommand="{Binding #Root.DataContext.AcceptCommand}"
                                                       RejectCommand="{Binding #Root.DataContext.RejectCommand}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
