<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Anduril.App.ViewModels"
             xmlns:models="using:Anduril.App.Models"
             xmlns:controls="using:Anduril.App.Views.Controls"
             x:Class="Anduril.App.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             xmlns:md="using:Markdown.Avalonia"
             Background="#0F1525">

    <UserControl.Styles>
        <!-- Rounded input -->
        <Style Selector="TextBox.chat-input">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="#0D1328" />
            <Setter Property="BorderBrush" Value="#1E2E50" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D0DCFF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="#6090D0" />
        </Style>
        <Style Selector="TextBox.chat-input:focus">
            <Setter Property="BorderBrush" Value="#3A5898" />
        </Style>
        <!-- Send button -->
        <Style Selector="Button.send">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Background" Value="#1E3A6E" />
            <Setter Property="Foreground" Value="#CCDEFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.send:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#264A8A" />
        </Style>
        <Style Selector="Button.send:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#111A2E" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <!-- Stop button -->
        <Style Selector="Button.stop">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#5A6A8A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.stop:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A2845" />
        </Style>
        <Style Selector="Button.stop:pointerover">
            <Setter Property="Foreground" Value="#C8A8A8" />
        </Style>
        <Style Selector="md|MarkdownScrollViewer TextBlock">
            <Setter Property="Foreground" Value="#C8D8F4" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <!-- Show more / Show less link -->
        <Style Selector="Button.show-more">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="#5A7AAA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.show-more:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.show-more:pointerover">
            <Setter Property="Foreground" Value="#7A9FCC" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- Input bar at bottom -->
        <Border DockPanel.Dock="Bottom"
                Background="#0B0F1E"
                BorderBrush="#161E35"
                BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Row="0" Grid.Column="0"
                         Classes="chat-input"
                         Text="{Binding InputText}"
                         Watermark="Message Anduril..."
                         AcceptsReturn="True"
                         MaxHeight="160"
                         VerticalContentAlignment="Top"
                         TextWrapping="Wrap">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Return" Command="{Binding SendCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Grid.Row="0" Grid.Column="1"
                        Classes="send"
                        Content="Send"
                        Command="{Binding SendCommand}"
                        IsVisible="{Binding !IsStreaming}"
                        Margin="10,0,0,0"
                        MinWidth="80" />
                <Button Grid.Row="0" Grid.Column="1"
                        Classes="stop"
                        Command="{Binding StopCommand}"
                        IsVisible="{Binding IsStreaming}"
                        Margin="10,0,0,0"
                        ToolTip.Tip="Stop generation">
                    <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2"
                               Fill="{Binding $parent[Button].Foreground}" />
                </Button>
            </Grid>
        </Border>

        <!-- Messages scroll area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <ItemsControl ItemsSource="{Binding Messages}"
                          Margin="20,16,20,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessageModel">
                        <!-- User: right-aligned; Assistant: left-aligned -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MaxWidth="640" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Assistant bubble (left) — spans all columns so it fills the full width -->
                            <Border Grid.Column="0" Grid.ColumnSpan="3"
                                    IsVisible="{Binding IsAssistant}"
                                    Background="#111A2E"
                                    CornerRadius="4,18,18,18"
                                    Padding="14,10"
                                    HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <Panel>
                                        <controls:StreamingDotIndicator IsStreaming="{Binding IsLoading}" />
                                        <Border MaxHeight="{Binding ContentMaxHeight}"
                                                ClipToBounds="True"
                                                IsVisible="{Binding !IsLoading}">
                                            <md:MarkdownScrollViewer Markdown="{Binding Content}" />
                                        </Border>
                                    </Panel>
                                    <Button Classes="show-more"
                                            IsVisible="{Binding IsCollapsible}"
                                            Command="{Binding ToggleExpandCommand}"
                                            Content="{Binding ShowMoreLabel}" />
                                </StackPanel>
                            </Border>

                            <!-- User bubble (right) -->
                            <Border Grid.Column="1" Grid.ColumnSpan="2"
                                    IsVisible="{Binding IsUser}"
                                    Background="#1A3360"
                                    CornerRadius="18,4,18,18"
                                    Padding="14,10"
                                    MaxWidth="560"
                                    HorizontalAlignment="Right">
                                <StackPanel>
                                    <Border MaxHeight="{Binding ContentMaxHeight}"
                                            ClipToBounds="True">
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   Foreground="#DCE8FF"
                                                   LineHeight="21" />
                                    </Border>
                                    <Button Classes="show-more"
                                            IsVisible="{Binding IsCollapsible}"
                                            Command="{Binding ToggleExpandCommand}"
                                            Content="{Binding ShowMoreLabel}" />
                                </StackPanel>
                            </Border>

                            <!-- Stopped indicator (left) -->
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="3"
                                        IsVisible="{Binding IsStopped}"
                                        Orientation="Horizontal"
                                        Spacing="7"
                                        HorizontalAlignment="Left">
                                <Rectangle Width="10" Height="10" RadiusX="1.5" RadiusY="1.5"
                                           Fill="#3A4A62" VerticalAlignment="Center" />
                                <TextBlock Text="Stopped"
                                           FontSize="12"
                                           Foreground="#3A4A62"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
