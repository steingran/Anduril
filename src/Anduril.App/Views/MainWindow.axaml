<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Anduril.App.ViewModels"
        xmlns:views="using:Anduril.App.Views"
        xmlns:models="using:Anduril.App.Models"
        xmlns:conv="using:Anduril.App.Converters"
        xmlns:controls="using:Anduril.App.Views.Controls"
        x:Class="Anduril.App.Views.MainWindow"
        x:Name="WindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Title="Anduril"
        Icon="/Assets/anduril-icon.ico"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="720"
        TransparencyLevelHint="Mica,AcrylicBlur,Blur"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AndurilSurfaceBrush}"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        KeyDown="OnWindowKeyDown">

    <Window.Styles>
        <Style Selector="Border.shell-surface">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
        </Style>

        <Style Selector="Border.sidebar-surface">
            <Setter Property="Background" Value="{DynamicResource AndurilSidebarBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilDividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style Selector="Border.topbar-surface">
            <Setter Property="Background" Value="{DynamicResource AndurilSidebarBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilDividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="Button.tools-toggle">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusPill}" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeUi}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.tools-toggle /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.tools-toggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.tools-toggle.active">
            <Setter Property="Background" Value="{DynamicResource AndurilAccentSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilAccentBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.tools-toggle:focus-visible /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilAccentBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilFocusVisibleThickness}" />
        </Style>

        <Style Selector="Border.conversation-item-root">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusM}" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem Border.conversation-stripe">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected Border.conversation-stripe">
            <Setter Property="Background" Value="{DynamicResource AndurilAccentBrush}" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem Button.conversation-more">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:pointerover Button.conversation-more,
                         ListBox.sidebar ListBoxItem:selected Button.conversation-more">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <Style Selector="ListBox.sidebar ListBoxItem TextBlock.conversation-title">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeUi}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="ListBox.sidebar ListBoxItem TextBlock.conversation-meta">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeCaption}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected TextBlock.conversation-title,
                         ListBox.sidebar ListBoxItem:selected:pointerover TextBlock.conversation-title">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected TextBlock.conversation-meta,
                         ListBox.sidebar ListBoxItem:selected:pointerover TextBlock.conversation-meta">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
        </Style>

        <Style Selector="Button.overlay-scrim">
            <Setter Property="Background" Value="{DynamicResource AndurilTextDisabledBrush}" />
            <Setter Property="Opacity" Value="0.22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Border.tool-inspector-panel">
            <Setter Property="Width" Value="{DynamicResource AndurilToolInspectorWidth}" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,-392,0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <ThicknessTransition Property="Margin" Duration="{DynamicResource AndurilMotionDurationSlow}" />
                    <DoubleTransition Property="Opacity" Duration="{DynamicResource AndurilMotionDurationDefault}" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.tool-inspector-panel.open">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border.tool-section-card">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusL}" />
            <Setter Property="Padding" Value="{DynamicResource AndurilPaddingCard}" />
        </Style>

        <Style Selector="Border.tool-chip">
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusS}" />
            <Setter Property="Padding" Value="{DynamicResource AndurilPaddingChip}" />
            <Setter Property="Margin" Value="0,0,4,4" />
        </Style>

        <Style Selector="Border.settings-dialog">
            <Setter Property="Width" Value="420" />
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Background" Value="{DynamicResource AndurilSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeStrongBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThicknessStrong}" />
            <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusXl}" />
            <Setter Property="Padding" Value="{DynamicResource AndurilPaddingPanel}" />
        </Style>

        <Style Selector="TextBlock.sidebar-title">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.sidebar-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Styles>

    <Border Classes="shell-surface">
        <Grid ColumnDefinitions="280,*">
            <Border Grid.Column="0"
                    Classes="sidebar-surface"
                    Padding="16,16,16,16">
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="16">
                    <StackPanel Grid.Row="0"
                                Spacing="12">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <controls:Brandmark Size="Small" />
                            <StackPanel Grid.Column="1"
                                        Spacing="0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Andúril"
                                           Classes="sidebar-title" />
                                <TextBlock Text="AI Assistant"
                                           Classes="sidebar-subtitle" />
                            </StackPanel>
                        </Grid>

                        <Button x:Name="NewConversationSidebarButton"
                                Classes="accent block"
                                Command="{Binding NewConversationCommand}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <PathIcon Width="{DynamicResource AndurilIconSizeS}"
                                          Height="{DynamicResource AndurilIconSizeS}"
                                          Data="{StaticResource FluentAdd16Geometry}" />
                                <TextBlock Text="New conversation" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding GroupedConversations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConversationGroup">
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Header}"
                                                   Classes="SidebarGroupHeader" />

                                        <ListBox Classes="sidebar"
                                                 ItemsSource="{Binding Conversations}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 SelectionMode="Single"
                                                 SelectedItem="{Binding $parent[Window].DataContext.SelectedConversation, Mode=TwoWay}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ConversationEntry">
                                                    <Border Classes="conversation-item-root">
                                                        <Grid ColumnDefinitions="2,*,Auto"
                                                              ColumnSpacing="10">
                                                            <Border Classes="conversation-stripe"
                                                                    Grid.Column="0"
                                                                    CornerRadius="{DynamicResource AndurilRadiusPill}" />

                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="2">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Classes="conversation-title"
                                                                           Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                                                                <TextBlock Text="{Binding CreatedAt.LocalDateTime, StringFormat='{}{0:ddd, MMM d · HH:mm}'}"
                                                                           Classes="conversation-meta"
                                                                           Foreground="{DynamicResource AndurilTextSecondaryBrush}" />
                                                            </StackPanel>

                                                            <Button Grid.Column="2"
                                                                    Classes="ghost icon conversation-more"
                                                                    HorizontalAlignment="Right">
                                                                <Button.Flyout>
                                                                    <MenuFlyout>
                                                                        <MenuItem Header="Rename"
                                                                                  Tag="{Binding}"
                                                                                  Click="OnRenameConversationClick" />
                                                                        <MenuItem Header="Delete"
                                                                                  Tag="{Binding}"
                                                                                  Click="OnDeleteConversationClick" />
                                                                    </MenuFlyout>
                                                                </Button.Flyout>
                                                                <PathIcon Width="{DynamicResource AndurilIconSizeS}"
                                                                          Height="{DynamicResource AndurilIconSizeS}"
                                                                          Data="{StaticResource FluentDismiss16Geometry}"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                                    <PathIcon.RenderTransform>
                                                                        <RotateTransform Angle="45" />
                                                                    </PathIcon.RenderTransform>
                                                                </PathIcon>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="12">
                        <Separator Background="{DynamicResource AndurilDividerBrush}" />
                        <Button x:Name="SettingsButton"
                                Grid.Row="1"
                                Classes="ghost"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Settings"
                                Command="{Binding OpenSettingsCommand}">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">
                                <PathIcon Width="{DynamicResource AndurilIconSizeM}"
                                          Height="{DynamicResource AndurilIconSizeM}"
                                          VerticalAlignment="Center"
                                          Data="{StaticResource FluentSettings20Geometry}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="Settings"
                                           FontSize="{DynamicResource AndurilFontSizeUi}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AndurilTextPrimaryBrush}" />
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*">
                <Border x:Name="TopBar"
                        Grid.Row="0"
                        Classes="topbar-surface"
                        Padding="16,12,16,12">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">
                        <controls:SegmentedControl x:Name="NavigationSegments"
                                                   Grid.Column="0"
                                                   Width="160"
                                                   ItemsSource="{Binding NavigationItems}"
                                                   SelectedIndex="{Binding SelectedNavigationIndex, Mode=TwoWay}" />

                        <Border x:Name="TitleBarDragRegion"
                                Grid.Column="1"
                                Background="Transparent"
                                MinHeight="32" />

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    HorizontalAlignment="Right">
                            <Button x:Name="ToolsToggleButton"
                                    Classes="tools-toggle"
                                    Classes.active="{Binding IsToolInspectorOpen}"
                                    Padding="10,8"
                                    Command="{Binding ToggleToolInspectorCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <PathIcon Width="{DynamicResource AndurilIconSizeS}"
                                              Height="{DynamicResource AndurilIconSizeS}"
                                              Data="{StaticResource FluentWrench16Geometry}" />
                                </StackPanel>
                            </Button>

                            <controls:ModelPicker x:Name="TopBarModelPicker"
                                                  Compact="True"
                                                  Width="176"
                                                  ItemsSource="{Binding AvailableModels}"
                                                  SelectedModel="{Binding SelectedModel}"
                                                  ConfigureCommand="{Binding OpenSettingsCommand}"
                                                  ConfigureLabel="Provider settings" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Panel Grid.Row="1"
                       ClipToBounds="True">
                    <ContentControl x:Name="MainContentHost"
                                    Content="{Binding CurrentView}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="vm:ChatViewModel">
                                <views:ChatView />
                            </DataTemplate>
                            <DataTemplate DataType="vm:CodeViewModel">
                                <views:CodeView />
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>

                    <Button x:Name="OverlayScrim"
                            Classes="overlay-scrim"
                            IsVisible="{Binding IsOverlayOpen}"
                            Command="{Binding CloseTransientPanelsCommand}" />

                    <Border x:Name="ToolInspectorPanel"
                            Classes="tool-inspector-panel"
                            HorizontalAlignment="Right"
                            ZIndex="20">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Padding="20,18,20,16"
                                    BorderBrush="{DynamicResource AndurilDividerBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Tool inspector"
                                                   Classes="Subtitle" />
                                        <TextBlock Text="Providers and integrations available in this session."
                                                   Classes="Caption" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Classes="ghost icon"
                                            Command="{Binding ToggleToolInspectorCommand}">
                                        <PathIcon Width="{DynamicResource AndurilIconSizeS}"
                                                  Height="{DynamicResource AndurilIconSizeS}"
                                                  Data="{StaticResource FluentDismiss16Geometry}" />
                                    </Button>
                                </Grid>
                            </Border>

                            <ScrollViewer Padding="20,20,20,24">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="AI PROVIDERS"
                                                   Classes="Overline" />
                                        <Border Classes="tool-section-card">
                                            <ItemsControl ItemsSource="{Binding ToolInspectorProviders}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ToolInspectorItem">
                                                        <StackPanel Margin="0,0,0,16"
                                                                    Spacing="8">
                                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                                  ColumnSpacing="10">
                                                                <Ellipse Width="8"
                                                                         Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding IsAvailable, Converter={x:Static conv:BoolToBrushConverter.Instance}}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Name}"
                                                                           Classes="Body" />
                                                                <Border Grid.Column="2"
                                                                        IsVisible="{Binding SupportsChatCompletion}"
                                                                        Background="{DynamicResource AndurilAccentSubtleBrush}"
                                                                        BorderBrush="{DynamicResource AndurilAccentBorderBrush}"
                                                                        BorderThickness="{DynamicResource AndurilStrokeThickness}"
                                                                        CornerRadius="{DynamicResource AndurilRadiusPill}"
                                                                        Padding="{DynamicResource AndurilPaddingChip}">
                                                                    <TextBlock Text="Chat"
                                                                               Classes="Caption"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <ItemsControl IsVisible="{Binding HasFunctions}"
                                                                          ItemsSource="{Binding Functions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="x:String">
                                                                        <Border Classes="tool-chip">
                                                                            <TextBlock Text="{Binding}"
                                                                                       Classes="Caption" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <TextBlock IsVisible="{Binding IsNotAvailable}"
                                                                       Text="Not running or not configured"
                                                                       Classes="Caption" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="INTEGRATIONS"
                                                   Classes="Overline" />
                                        <Border Classes="tool-section-card">
                                            <ItemsControl ItemsSource="{Binding ToolInspectorIntegrations}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ToolInspectorItem">
                                                        <StackPanel Margin="0,0,0,16"
                                                                    Spacing="8">
                                                            <Grid ColumnDefinitions="Auto,*"
                                                                  ColumnSpacing="10">
                                                                <Ellipse Width="8"
                                                                         Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding IsAvailable, Converter={x:Static conv:BoolToBrushConverter.Instance}}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Name}"
                                                                           Classes="Body" />
                                                            </Grid>

                                                            <TextBlock IsVisible="{Binding HasDescription}"
                                                                       Text="{Binding Description}"
                                                                       TextWrapping="Wrap"
                                                                       Classes="Caption" />

                                                            <ItemsControl IsVisible="{Binding HasFunctions}"
                                                                          ItemsSource="{Binding Functions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="x:String">
                                                                        <Border Classes="tool-chip">
                                                                            <TextBlock Text="{Binding}"
                                                                                       Classes="Caption" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border x:Name="SettingsDialog"
                            Classes="settings-dialog"
                            IsVisible="{Binding IsSettingsOpen}"
                            ZIndex="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Settings"
                                           Classes="Title" />
                                <TextBlock Text="The full settings surface is still landing. This placeholder confirms the sidebar and model picker routes are wired."
                                           TextWrapping="Wrap"
                                           Classes="Caption" />
                            </StackPanel>

                            <Border Background="{DynamicResource AndurilSurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource AndurilStrokeBrush}"
                                    BorderThickness="{DynamicResource AndurilStrokeThickness}"
                                    CornerRadius="{DynamicResource AndurilRadiusL}"
                                    Padding="{DynamicResource AndurilPaddingCard}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Planned sections"
                                               Classes="Body" />
                                    <TextBlock Text="Provider management, theme/motion preferences, and workspace defaults."
                                               TextWrapping="Wrap"
                                               Classes="Caption" />
                                </StackPanel>
                            </Border>

                            <Button x:Name="CloseSettingsButton"
                                    Classes="accent"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CloseSettingsCommand}">
                                <TextBlock Text="Close" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Panel>
            </Grid>
        </Grid>
    </Border>
</Window>
