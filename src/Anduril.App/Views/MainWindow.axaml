<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Anduril.App.ViewModels"
        xmlns:views="using:Anduril.App.Views"
        xmlns:models="using:Anduril.App.Models"
        xmlns:conv="using:Anduril.App.Converters"
        x:Class="Anduril.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Andúril"
        Icon="/Assets/anduril-icon.ico"
        Width="1120" Height="760"
        MinWidth="800" MinHeight="500"
        Background="#0D1126"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Pill tab button base -->
        <Style Selector="Button.tab">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#99AABB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A2845" />
        </Style>
        <!-- Active pill -->
        <Style Selector="Button.tab.active">
            <Setter Property="Background" Value="#1E2E50" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Button.tab.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#243660" />
        </Style>

        <!-- Nav rail icon buttons -->
        <Style Selector="Button.nav">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A2845" />
        </Style>

        <!-- New conversation pill -->
        <Style Selector="Button.new-convo">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="#1E3A6E" />
            <Setter Property="Foreground" Value="#CCDEFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.new-convo:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#264A8A" />
        </Style>

        <!-- Tool inspector toggle button -->
        <Style Selector="Button.tools-btn">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#0D1328" />
            <Setter Property="BorderBrush" Value="#1E2E50" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#6090D0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.tools-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#141E36" />
        </Style>
        <Style Selector="Button.tools-btn.active">
            <Setter Property="BorderBrush" Value="#3A6EC0" />
            <Setter Property="Foreground" Value="#A8C8FF" />
        </Style>

        <!-- Sidebar conversation list items -->
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2E50" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#141E36" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">

        <!-- ═══════════════════════════════════════════════════
             LEFT SIDEBAR — Nav rail: logo, history, settings
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#0B0F1E"
                BorderBrush="#161E35"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="16,20,16,16"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/anduril-icon.ico" Width="28" Height="28" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Andúril"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#E8EDF8" />
                        <TextBlock Text="AI Assistant"
                                   FontSize="11"
                                   Foreground="#5A6A8A" />
                    </StackPanel>
                </StackPanel>

                <!-- Settings at bottom -->
                <StackPanel DockPanel.Dock="Bottom"
                            Margin="12,8,12,16"
                            Spacing="2">
                    <Separator Background="#161E35" Margin="0,0,0,8" />
                    <Button Classes="nav"
                            ToolTip.Tip="Settings"
                            HorizontalAlignment="Left">
                        <!-- Settings gear SVG path -->
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#7A8AA0"
                                      Data="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.45c.04-.32.07-.64.07-.97s-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1s.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.66z" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <!-- Conversation history -->
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="14,4,12,6"
                                Spacing="8">
                        <TextBlock Text="Recent"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#4A5A78"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Conversations}"
                             Background="Transparent"
                             Padding="8,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#8A9BBB"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             MAIN CONTENT — top bar + chat/code area
             ═══════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="1" Background="#0F1525">

            <!-- Top bar -->
            <Border DockPanel.Dock="Top"
                    Background="#0B0F1E"
                    BorderBrush="#161E35"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

                    <!-- Pill tab group -->
                    <Border Grid.Column="0"
                            Background="#0D1328"
                            CornerRadius="22"
                            Padding="3">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Classes="tab"
                                    Classes.active="{Binding IsChatActive}"
                                    Content="Chat"
                                    Command="{Binding SwitchToChatCommand}" />
                            <Button Classes="tab"
                                    Classes.active="{Binding IsCodeActive}"
                                    Content="Code"
                                    Command="{Binding SwitchToCodeCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Tool inspector toggle -->
                    <Button Grid.Column="2"
                            Classes="tools-btn"
                            Classes.active="{Binding IsToolInspectorOpen}"
                            Command="{Binding ToggleToolInspectorCommand}"
                            ToolTip.Tip="View available tools"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Viewbox Width="13" Height="13" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#6090D0"
                                          Data="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Tools" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Model selector — capped width so long names don't crowd the New button -->
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel}"
                              MinWidth="160"
                              MaxWidth="260"
                              CornerRadius="16"
                              Padding="14,6"
                              Background="#0D1328"
                              BorderBrush="#1E2E50"
                              Foreground="#8A9BBB"
                              PlaceholderText="Select model..."
                              Margin="0,0,8,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="#C0CFEE"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- New conversation -->
                    <Button Grid.Column="4"
                            Classes="new-convo"
                            Content="+ New"
                            Command="{Binding NewConversationCommand}" />
                </Grid>
            </Border>

            <!-- Chat / Code content area with Tool Inspector overlay -->
            <Panel>
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:ChatViewModel">
                            <views:ChatView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CodeViewModel">
                            <views:CodeView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>

                <!-- ═══════════════════════════════════════════════════
                     TOOL INSPECTOR — right-side overlay panel
                     ═══════════════════════════════════════════════════ -->
                <Border IsVisible="{Binding IsToolInspectorOpen}"
                        Width="320"
                        HorizontalAlignment="Right"
                        Background="#0B0F1E"
                        BorderBrush="#1E2E50"
                        BorderThickness="1,0,0,0"
                        ZIndex="10">
                    <DockPanel>

                        <!-- Header -->
                        <Border DockPanel.Dock="Top"
                                BorderBrush="#161E35"
                                BorderThickness="0,0,0,1"
                                Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Tool Inspector"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#E8EDF8"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Command="{Binding ToggleToolInspectorCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#5A6A8A"
                                        FontSize="16"
                                        Padding="6,2"
                                        CornerRadius="6"
                                        Cursor="Hand" />
                            </Grid>
                        </Border>

                        <!-- Scrollable body -->
                        <ScrollViewer Padding="14,14,14,20">
                            <StackPanel Spacing="20">

                                <!-- AI Providers -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="AI PROVIDERS"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#4A5A78"
                                               LetterSpacing="0.6" />
                                    <Border Background="#0D1328"
                                            BorderBrush="#1A2845"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <ItemsControl ItemsSource="{Binding ToolInspectorProviders}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ToolInspectorItem">
                                                    <Border Padding="12,10"
                                                            BorderBrush="#141E36"
                                                            BorderThickness="0,0,0,1">
                                                        <StackPanel Spacing="6">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <Ellipse Width="8" Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding IsAvailable, Converter={x:Static conv:BoolToBrushConverter.Instance}}" />
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#C8D8F4"
                                                                           VerticalAlignment="Center" />
                                                                <Border IsVisible="{Binding SupportsChatCompletion}"
                                                                        Background="#1A3A5E"
                                                                        CornerRadius="10"
                                                                        Padding="7,2">
                                                                    <TextBlock Text="Chat"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#6090D0" />
                                                                </Border>
                                                            </StackPanel>
                                                            <ItemsControl IsVisible="{Binding HasFunctions}"
                                                                          ItemsSource="{Binding Functions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="x:String">
                                                                        <Border Background="#111A2E"
                                                                                CornerRadius="4"
                                                                                Padding="7,2"
                                                                                Margin="2,2,0,0">
                                                                            <TextBlock Text="{Binding}"
                                                                                       FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                                                                       FontSize="10"
                                                                                       Foreground="#8A9BBB" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBlock IsVisible="{Binding IsNotAvailable}"
                                                                       Text="Not running or not configured"
                                                                       FontSize="11"
                                                                       FontStyle="Italic"
                                                                       Foreground="#5A3A3A" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>

                                <!-- Integration Tools -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="INTEGRATION TOOLS"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#4A5A78"
                                               LetterSpacing="0.6" />
                                    <Border Background="#0D1328"
                                            BorderBrush="#1A2845"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <ItemsControl ItemsSource="{Binding ToolInspectorIntegrations}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ToolInspectorItem">
                                                    <Border Padding="12,10"
                                                            BorderBrush="#141E36"
                                                            BorderThickness="0,0,0,1">
                                                        <StackPanel Spacing="5">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <Ellipse Width="8" Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding IsAvailable, Converter={x:Static conv:BoolToBrushConverter.Instance}}" />
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#C8D8F4"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <TextBlock IsVisible="{Binding HasDescription}"
                                                                       Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Foreground="#4A5A78"
                                                                       TextWrapping="Wrap" />
                                                            <ItemsControl IsVisible="{Binding HasFunctions}"
                                                                          ItemsSource="{Binding Functions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="x:String">
                                                                        <Border Background="#111A2E"
                                                                                CornerRadius="4"
                                                                                Padding="7,2"
                                                                                Margin="2,2,0,0">
                                                                            <TextBlock Text="{Binding}"
                                                                                       FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                                                                       FontSize="10"
                                                                                       Foreground="#8A9BBB" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBlock IsVisible="{Binding IsNotAvailable}"
                                                                       Text="Not configured — add credentials in settings"
                                                                       FontSize="11"
                                                                       FontStyle="Italic"
                                                                       Foreground="#5A3A3A" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Panel>
        </DockPanel>
    </Grid>
</Window>
