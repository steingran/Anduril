<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>

            <!-- Font families -->
            <FontFamily x:Key="AndurilFontFamilyUi">avares://Avalonia.Fonts.Inter/Assets#Inter, $Default</FontFamily>
            <FontFamily x:Key="AndurilFontFamilyMono">Cascadia Code, Consolas, Menlo, monospace</FontFamily>

            <!-- Font sizes -->
            <x:Double x:Key="AndurilFontSizeDisplay">28</x:Double>
            <x:Double x:Key="AndurilFontSizeTitle">20</x:Double>
            <x:Double x:Key="AndurilFontSizeSubtitle">16</x:Double>
            <x:Double x:Key="AndurilFontSizeBody">14</x:Double>
            <x:Double x:Key="AndurilFontSizeUi">13</x:Double>
            <x:Double x:Key="AndurilFontSizeCaption">12</x:Double>
            <x:Double x:Key="AndurilFontSizeOverline">11</x:Double>
            <x:Double x:Key="AndurilFontSizeMono">13</x:Double>
            <x:Double x:Key="AndurilFontSizeMonoSmall">11</x:Double>

            <!-- Line heights -->
            <x:Double x:Key="AndurilLineHeightDisplay">36</x:Double>
            <x:Double x:Key="AndurilLineHeightTitle">28</x:Double>
            <x:Double x:Key="AndurilLineHeightSubtitle">24</x:Double>
            <x:Double x:Key="AndurilLineHeightBodyStrong">20</x:Double>
            <x:Double x:Key="AndurilLineHeightBody">22</x:Double>
            <x:Double x:Key="AndurilLineHeightUi">18</x:Double>
            <x:Double x:Key="AndurilLineHeightCaption">16</x:Double>
            <x:Double x:Key="AndurilLineHeightOverline">14</x:Double>
            <x:Double x:Key="AndurilLineHeightMono">20</x:Double>
            <x:Double x:Key="AndurilLineHeightMonoSmall">16</x:Double>

        </ResourceDictionary>
    </Styles.Resources>

    <!-- TextBlock style classes -->
    <Style Selector="TextBlock.Display">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightDisplay}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Title">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightTitle}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Subtitle">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightSubtitle}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.BodyStrong">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightBodyStrong}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Body">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightBody}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Ui">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeUi}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightUi}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Caption">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeCaption}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Overline">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyUi}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeOverline}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightOverline}" />
        <Setter Property="LetterSpacing" Value="0.6" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.Mono">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeMono}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightMono}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.MonoSmall">
        <Setter Property="FontFamily" Value="{StaticResource AndurilFontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource AndurilFontSizeMonoSmall}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource AndurilLineHeightMonoSmall}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
    </Style>

</Styles>
