<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Markdown fallback styles. Full markdown rendering via md controls is  -->
    <!-- intentionally removed to keep the desktop layer Avalonia-12-safe.     -->

    <!-- Inline code chip -->
    <Style Selector="TextBlock.MarkdownInlineCode">
        <Setter Property="FontFamily" Value="{DynamicResource AndurilFontFamilyMono}" />
        <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeMonoSmall}" />
        <Setter Property="Background" Value="{DynamicResource AndurilCodeSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        <Setter Property="Padding" Value="{DynamicResource AndurilPaddingChip}" />
    </Style>

    <!-- Code-block surface -->
    <Style Selector="Border.MarkdownCodeBlock">
        <Setter Property="Background" Value="{DynamicResource AndurilCodeSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AndurilStrokeBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource AndurilStrokeThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource AndurilRadiusM}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.MarkdownCodeHeader">
        <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="TextBlock.MarkdownCodeLanguage">
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.MarkdownCodeText">
        <Setter Property="Foreground" Value="{DynamicResource AndurilTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AndurilFontFamilyMono}" />
        <Setter Property="FontSize" Value="{DynamicResource AndurilFontSizeMonoSmall}" />
        <Setter Property="Padding" Value="{DynamicResource AndurilPaddingCard}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Blockquote -->
    <Style Selector="Border.MarkdownBlockquote">
        <Setter Property="Background" Value="{DynamicResource AndurilSurfaceSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AndurilAccentBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="Padding" Value="{DynamicResource AndurilPaddingCard}" />
    </Style>

</Styles>
