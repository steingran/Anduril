<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:anim="clr-namespace:Avalonia.Animation.Easings;assembly=Avalonia.Base">

    <!-- Durations (Doherty: feedback 100 ms, transitions 250 ms, panel slides 300 ms) -->
    <sys:TimeSpan x:Key="AndurilMotionDurationFast">0:0:0.12</sys:TimeSpan>
    <sys:TimeSpan x:Key="AndurilMotionDurationDefault">0:0:0.20</sys:TimeSpan>
    <sys:TimeSpan x:Key="AndurilMotionDurationSlow">0:0:0.30</sys:TimeSpan>
    <sys:TimeSpan x:Key="AndurilMotionDurationZero">0:0:0</sys:TimeSpan>

    <!-- Easings -->
    <anim:CubicEaseOut x:Key="AndurilMotionEaseStandard" />
    <anim:BackEaseOut x:Key="AndurilMotionEaseEmphasis" />

</ResourceDictionary>
