{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AI": {
    "OpenAI": {
      "Enabled": true,
      "Provider": "openai",
      "Model": "",
      "ApiKey": "",
      "Endpoint": null
    },
    "Anthropic": {
      "Enabled": true,
      "Provider": "anthropic",
      "Model": "claude-sonnet-4-5",
      "ApiKey": "",
      "EnablePromptCaching": true
    },
    "Augment": {
      "Enabled": true,
      "Provider": "augment",
      "AugmentCliPath": "auggie"
    },
    "AugmentChat": {
      "Enabled": true,
      "Provider": "augment-chat",
      "Model": "claude-sonnet-4-20250514",
      "ApiKey": "",
      "Endpoint": "https://d10.api.augmentcode.com"
    },
    "Ollama": {
      "Enabled": true,
      "Provider": "ollama",
      "Model": "",
      "Endpoint": "http://localhost:11434"
    },
    "LLamaSharp": {
      "Enabled": true,
      "Provider": "llamasharp",
      "ModelPath": ""
    }
  },
  "Communication": {
    "Cli": {
      "Enabled": true
    },
    "Slack": {
      "Enabled": true,
      "BotToken": "",
      "AppToken": ""
    },
    "Teams": {
      "Enabled": true,
      "MicrosoftAppId": "",
      "MicrosoftAppPassword": ""
    },
    "Signal": {
      "Enabled": true,
      "PhoneNumber": "",
      "ApiUrl": "http://localhost:9080",
      "PollingIntervalSeconds": 2
    }
  },
  "Integrations": {
    "GitHub": {
      "Token": "",
      "DefaultOwner": "",
      "DefaultRepo": ""
    },
    "Sentry": {
      "AuthToken": "",
      "Organization": "",
      "Project": "",
      "BaseUrl": "https://sentry.io/api/0/"
    },
    "Office365Calendar": {
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "UserId": ""
    },
    "Gmail": {
      "ClientId": "",
      "ClientSecret": "",
      "RefreshToken": "",
      "UserId": "me",
      "PubSubTopic": "",
      "AttachmentSavePath": "attachments",
      "ImportantSenders": [],
      "Rules": []
    },
    "SlackQuery": {
      "DefaultMessageLimit": 20,
      "MaximumMessageLimit": 100,
      "SearchPageSize": 100,
      "MaximumSearchPages": 10
    },
    "MediumArticle": {
      "RetrievalMode": "BrowserOnly",
      "CacheDurationMinutes": 60,
      "BrowserUserDataDirectory": "",
      "BrowserRemoteDebuggingUrl": "http://127.0.0.1:9222",
      "BrowserChannel": "",
      "BrowserExecutablePath": "",
      "BrowserHeadless": false,
      "BrowserNavigationTimeoutSeconds": 60,
      "BrowserManualInterventionWaitSeconds": 120,
      "BrowserManualInterventionRetryCount": 0,
      "RequestTimeoutSeconds": 20,
      "UserAgent": "",
      "MaximumContentLengthCharacters": 20000
    }
  },
  "ConversationSessions": {
    "SessionsDirectory": "./sessions",
    "MaxTokens": 100000
  },
  "Skills": {
    "SkillsDirectory": "skills"
  },
  "StandupScheduler": {
    "Enabled": true,
    "Schedule": "25 9 * * 1,3",
    "TargetPlatform": "slack",
    "TargetChannel": "standup",
    "GitHubOrganization": ""
  },
  "GmailScheduler": {
    "Enabled": false,
    "Schedule": "0 7 * * 1,2,3,4,5",
    "TargetPlatform": "slack",
    "TargetChannel": "",
    "SummaryHours": 12
  },
  "SentryBugfix": {
    "Enabled": false,
    "OccurrenceThreshold": 10,
    "NotificationPlatform": "slack",
    "NotificationChannel": "",
    "AugmentCliPath": "auggie",
    "BranchPrefix": "sentry-bugfix/",
    "AuggieTimeoutMinutes": 10,
    "BaseBranch": "main"
  },
  "Updates": {
    "Url": "",
    "CheckIntervalMinutes": 60
  }
}
