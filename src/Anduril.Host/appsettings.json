    "Office365Calendar": {
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "UserId": ""
    },
    "Gmail": {
      "ClientId": "",
      "ClientSecret": "",
      "RefreshToken": "",
      "UserId": "me",
      "PubSubTopic": "",
      "AttachmentSavePath": "attachments",
      "ImportantSenders": [],
      "Rules": []
