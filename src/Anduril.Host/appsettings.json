      "Provider": "openai",
      "Model": "gpt-4o",
      "ApiKey": "",
      "Endpoint": null
    },
    "Anthropic": {
      "Provider": "anthropic",
      "Model": "claude-sonnet-4-5",
      "ApiKey": "",
      "EnablePromptCaching": true
    },
    "Augment": {
      "Provider": "augment",
      "AugmentCliPath": "auggie"
    },
    "AugmentChat": {
      "Provider": "augment-chat",
      "Model": "claude-sonnet-4-20250514",
      "ApiKey": "",
      "Endpoint": "https://d10.api.augmentcode.com"
    },
    "Ollama": {
      "Provider": "ollama",
      "Model": "qwen2.5:7b",
      "Endpoint": "http://localhost:11434"
    },
    "LLamaSharp": {
      "Provider": "llamasharp",
      "ModelPath": ""
    }
  },

  "Communication": {
    "Slack": {
      "BotToken": "",
      "AppToken": ""
    },
    "Teams": {
      "MicrosoftAppId": "",
      "MicrosoftAppPassword": ""
    },
    "Signal": {
      "PhoneNumber": "",
